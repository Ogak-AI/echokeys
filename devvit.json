{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "echokeys",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      },
      "leaderboard": {
        "entry": "leaderboard.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "permissions": {
    "redis": true,
    "realtime": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_POST"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create Echokeys Challenge",
        "description": "Post a random 2000+ word race from the built-in source pool",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/create-challenge",
        "postFilter": "none"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "weekly-snapshot": {
        "endpoint": "/internal/weekly-snapshot",
        "cron": "0 0 * * 0"
      },
      "monthly-snapshot": {
        "endpoint": "/internal/monthly-snapshot",
        "cron": "0 0 1 * *"
      },
      "yearly-snapshot": {
        "endpoint": "/internal/yearly-snapshot",
        "cron": "0 0 1 1 *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "dev": {
    "subreddit": "echokeys_dev"
  }
}
