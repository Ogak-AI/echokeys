{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "echokeys",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      },
      "leaderboard": {
        "entry": "leaderboard.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    },
    "redis": true,
    "realtime": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBMIT_POST"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create Echokeys Challenge",
        "description": "Generate a typing challenge from a prompt and post it",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/create-challenge",
        "postFilter": "none"
      }
    ]
  },
  "forms": {
    "create-challenge": "/internal/form/create-challenge"
  },
  "settings": {
    "global": {
      "gemini_api_key": {
        "type": "string",
        "label": "Gemini API Key (free tier)",
        "helpText": "Free key from aistudio.google.com/apikey. Only Google Gemini free-tier models are used — no paid providers.",
        "isSecret": true
      },
      "gemini_model": {
        "type": "string",
        "label": "Gemini Model (free intelligent only)",
        "helpText": "Allowlisted free models only: gemini-3.6-flash (default), gemini-3.5-flash, gemini-2.5-pro, gemini-2.5-flash. Paid/lite models are rejected.",
        "defaultValue": "gemini-3.6-flash"
      }
    }
  },
  "scheduler": {
    "tasks": {
      "weekly-snapshot": {
        "endpoint": "/internal/weekly-snapshot",
        "cron": "0 0 * * 0"
      },
      "monthly-snapshot": {
        "endpoint": "/internal/monthly-snapshot",
        "cron": "0 0 1 * *"
      },
      "yearly-snapshot": {
        "endpoint": "/internal/yearly-snapshot",
        "cron": "0 0 1 1 *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "dev": {
    "subreddit": "echokeys_dev"
  }
}
