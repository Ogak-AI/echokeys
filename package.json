{
  "private": true,
  "name": "echokeys",
  "version": "1.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd src/client && vite build",
    "build:server": "cd src/server && vite build",
    "check": "tsc --build",
    "deploy": "npm run build && devvit upload",
    "dev": "npm run build && devvit playtest",
    "dev:client": "cd src/client && vite build --watch",
    "dev:server": "cd src/server && vite build --watch",
    "login": "devvit login",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@devvit/server": "^0.13.8",
    "@devvit/web": "^0.13.8",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@devvit/cli": "^0.13.8",
    "@tailwindcss/vite": "^4.1.6",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.23.1",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  }
}
