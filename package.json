{
  "private": true,
  "name": "echokeys",
  "version": "1.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:types": "tsc -p tests/tsconfig.json",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd src/client && vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd src/client && vite build",
    "build:server": "tsc -b src/shared/tsconfig.json src/server/tsconfig.json",
    "check": "tsc --noEmit",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src"
  },
  "dependencies": {
    "@devvit/server": "^0.12.24",
    "@devvit/web": "^0.12.24",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@devvit/cli": "^0.12.24",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  }
}
